<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#16213e"
    android:padding="14dp"
    android:layout_margin="8dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tvAdminIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:textSize="24sp"
        android:gravity="center"
        android:layout_marginEnd="12dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAdminTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvAdminCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#e63946"
            android:textSize="11sp"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnEdit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Edit"
        android:textSize="11sp"
        android:backgroundTint="#457b9d"
        android:textColor="#ffffff"
        android:layout_marginEnd="6dp"/>

    <Button
        android:id="@+id/btnAdminDelete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✕"
        android:textSize="11sp"
        android:backgroundTint="#880000"
        android:textColor="#ffffff"/>

</LinearLayout>