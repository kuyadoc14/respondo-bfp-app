<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- BFP Logo area -->

    <!-- SOS button -->

    <!-- Status card -->

    <LinearLayout
        android:id="@+id/headerArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="52dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥"
            android:textSize="50sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:letterSpacing="0.05"
            android:text="RESPONDO"
            android:textColor="#FFFFFF"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:letterSpacing="0.05"
            android:text="Bureau of Fire Protection"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Emergency Alert System"
            android:textColor="#888888"
            android:textSize="12sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/sosArea"
        android:layout_width="match_parent"
        android:layout_height="299dp"
        android:layout_below="@+id/headerArea"
        android:layout_marginTop="19dp"
        android:gravity="center"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnSOS"
            android:layout_width="210dp"
            android:layout_height="210dp"
            android:background="@drawable/glow_button"
            android:elevation="12dp"
            android:stateListAnimator="@null"
            android:text="SOS"
            android:textColor="#FFFFFF"
            android:textSize="52sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvInstruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Press to alert BFP immediately"
            android:textColor="#888888"
            android:textSize="13sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/statusCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_below="@id/sosArea"
        android:layout_marginTop="20dp"
        android:layout_centerHorizontal="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="10dp">

            <View
                android:id="@+id/pulseDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/circle_dot"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE"
                android:textColor="@color/warning"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"/>

    </LinearLayout>

</RelativeLayout>