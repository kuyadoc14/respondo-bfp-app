<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="56dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥"
            android:textSize="32sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bureau of Fire Protection"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emergency Alert System"
            android:textColor="#666666"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- SOS button centered -->
    <LinearLayout
        android:id="@+id/sosCenter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true">

        <!-- Outer glow ring -->
        <FrameLayout
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_gravity="center">

            <!-- Ring 1 -->
            <View
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:background="@drawable/circle_ring_outer"
                android:alpha="0.15"/>

            <!-- Ring 2 -->
            <View
                android:layout_width="210dp"
                android:layout_height="210dp"
                android:background="@drawable/circle_ring_mid"
                android:alpha="0.25"
                android:layout_gravity="center"/>

            <!-- SOS Button -->
            <Button
                android:id="@+id/btnSOS"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:text="SOS"
                android:textSize="44sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_sos_button"
                android:stateListAnimator="@null"
                android:elevation="0dp"/>

        </FrameLayout>

        <TextView
            android:id="@+id/tvInstruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Press to alert BFP immediately"
            android:textColor="#666666"
            android:textSize="13sp"
            android:layout_marginTop="24dp"/>

    </LinearLayout>

    <!-- Status card -->
    <LinearLayout
        android:id="@+id/statusCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_below="@id/sosCenter"
        android:layout_marginTop="16dp"
        android:layout_centerHorizontal="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <View
                android:id="@+id/pulseDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/circle_dot"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE"
                android:textColor="@color/warning"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"/>

    </LinearLayout>

    <!-- Floating voice assistant button -->
    <LinearLayout
        android:id="@+id/btnVoice"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:background="@drawable/bg_mic_button"
        android:gravity="center"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="24dp"
        android:layout_marginEnd="24dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎙"
            android:textSize="24sp"/>

    </LinearLayout>

</RelativeLayout>